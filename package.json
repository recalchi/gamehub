{
  "name": "gamehub",
  "version": "0.1.0",
  "description": "A fullscreen game launcher and emulator hub for PC, inspired by modern console interfaces.",
  "main": "out/main/index.cjs",
  "author": "GameHub",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win --dir",
    "dist:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win nsis --x64",
    "dist:win:portable": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win dir --x64 && node scripts/package-portable.mjs",
    "dist:win:full": "npm run dist:win && npm run dist:win:portable && npm run manifest:win",
    "icon:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\generate-app-icon.ps1",
    "manifest:win": "node scripts/generate-update-manifest.mjs",
    "publish:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win nsis --x64 --publish always",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "build": {
    "appId": "com.recalchi.gamehub",
    "productName": "GameHub",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "recalchi",
        "repo": "gamehub",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "GameHub-Setup-${arch}-${version}.${ext}",
      "verifyUpdateCodeSignature": true,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "pt_BR",
        "en_US"
      ]
    }
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^11.15.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
