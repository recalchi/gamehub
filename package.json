{
  "name": "gamehub",
  "version": "0.3.0",
  "description": "A fullscreen game launcher and emulator hub for PC, inspired by modern console interfaces.",
  "main": "out/main/index.cjs",
  "author": "GameHub",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:no-auto-admin": "set \"GAMEHUB_NO_AUTO_ADMIN=1\" && electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win --dir",
    "dist:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win nsis --x64",
    "dist:win:portable": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win dir --x64 && node scripts/package-portable.mjs",
    "dist:win:full": "npm run dist:win && npm run dist:win:portable && npm run manifest:win",
    "icon:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\generate-app-icon.ps1",
    "manifest:win": "node scripts/generate-update-manifest.mjs",
    "publish:win": "electron-vite build && set \"ELECTRON_CACHE=%CD%\\.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=%CD%\\.cache\\electron-builder\" && electron-builder --win nsis --x64 --publish always",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest"
  },
  "build": {
    "appId": "com.recalchi.gamehub",
    "productName": "GameHub",
    "afterPack": "scripts/after-pack-icon.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "recalchi",
        "repo": "gamehub",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "GameHub-Setup-${arch}.${ext}",
      "verifyUpdateCodeSignature": true,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "include": "build/installer.nsh",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": "GameHub",
      "shortcutName": "GameHub",
      "uninstallDisplayName": "GameHub ${version}",
      "installerLanguages": [
        "pt_BR",
        "en_US"
      ],
      "differentialPackage": true
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "6.8.9",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.42.2",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
